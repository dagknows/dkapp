## V6 / MCP — operator-configurable
# Service-to-service auth token used by both taskservice and mcp-server.
# Leave empty for basic operation. Set to a long-lived JWT issued by req-router
# to enable JWT public-key pre-warm (improves reliability under load).
V6_MCP_SERVICE_TOKEN=

# Persistent MCP connection pool. Default OFF — keeps memory low.
# Set to "true" on high-concurrency sites to cut MCP session-start latency.
V6_MCP_PERSISTENT_POOL=false

# MCP UI default selections (optional).
V6_MCP_DEFAULT_PROXY=
V6_MCP_DEFAULT_WORKSPACE=

# CORS allow-list for the mcp-server HTTP endpoint (comma-separated origins).
# Empty means "allow any origin". Lock down for public-facing deployments.
V6_MCP_ALLOWED_ORIGINS=

## LLM provider tuning (referenced by taskservice for V6 + classic Hercules)
# Max retries for LLM completion calls before giving up.
LLM_MAX_RETRY_COUNT=21

# Route embeddings through litellm (recommended; supports OpenAI / Azure / etc).
USE_LITELLM_EMBEDDINGS=true

# Azure-routed OpenAI (leave empty if not using Azure). Required only if the
# active LLM model targets an Azure deployment.
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
